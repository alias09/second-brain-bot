# Токен вашего Telegram бота (получить у @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# OpenAI API Key (для GPT-4 и Whisper)
OPENAI_API_KEY=your_openai_api_key_here

# Абсолютный путь к вашему хранилищу Obsidian на Mac.
# Автоматически найденный путь:
OBSIDIAN_VAULT_PATH=/Users/kvp/Library/CloudStorage/GoogleDrive-alias13.95@gmail.com/Мой диск/ObsidianVault

# Рекомендация по моделям:
# - Текст: gpt-4o-mini (очень дешевая и умная)
# - Аудио: Whisper API (отличная цена/качество)
# OPENAI_BASE_URL=http://host.docker.internal:11434/v1
# OPENAI_API_KEY=ollama
